{
  "name": "gkhr-interview-assistant",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "build": "npm run build:ui && npm run build:server",
    "build:server": "tsc",
    "build:ui": "vite build --config ui/vite.config.ts",
    "start": "node dist/index.js",
    "test": "npm run build:ui && vitest run --dir src",
    "typecheck": "npm run typecheck:server && npm run typecheck:ui",
    "typecheck:server": "tsc --noEmit",
    "typecheck:ui": "tsc --project ui/tsconfig.json --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@deepgram/sdk": "^5.3.0",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.1",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "prettier": "^3.8.3",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  }
}
